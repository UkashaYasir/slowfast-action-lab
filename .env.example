GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Inference confidence below this percentage is reported as "uncertain".
CONFIDENCE_THRESHOLD=25
TOP1_MIN_CONFIDENCE=52
TOP1_TOP2_GAP_THRESHOLD=12

# Local upload safety limits.
MAX_UPLOAD_MB=200
MIN_UPLOAD_BYTES=1024

# Local data/cache paths.
NV_UPLOAD_DIR=data/uploads
NV_DATA_DIR=data
TORCH_HUB_DIR=data/model_cache/torch_hub
KINETICS_LABELS_PATH=kinetics_classnames.json
EVALUATION_MANIFEST_PATH=data/evaluation/manifest.jsonl
EVALUATION_REPORT_DIR=data/evaluation/reports
NORMALIZED_VIDEO_DIR=data/uploads/normalized

# Preprocessing controls for more stable inference on mobile and mixed-format clips.
TARGET_CLIP_SECONDS=4
MAX_SOURCE_SECONDS=8
NORMALIZE_CONTAINER_FOR_INFERENCE=1

# Reserved for a future reviewed/labeled dataset training command.
RETRAINING_COMMAND=
